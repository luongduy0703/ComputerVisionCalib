<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS profile for Digital Twin over Pi Wi-Fi hotspot.
  Disables multicast discovery and uses unicast peers only.
  Use on BOTH Pi and Laptop.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <participant profile_name="participant_profile" is_default_profile="true">
        <rtps>
            <builtin>
                <!-- Remove empty elements that crash the parser! -->
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>192.168.50.1</address>
                        </udpv4>
                    </locator>
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
            </builtin>
        </rtps>
    </participant>
</profiles>
