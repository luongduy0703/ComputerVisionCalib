  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/new_arm/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="nylon_66_white"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/new_arm/base_link.stl" scale="0.001 0.001 0.001"/>
