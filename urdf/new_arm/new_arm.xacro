<!-- ========== CAMERA ========== -->
<link name="camera_link">
  <inertial>
    <mass value="0.01"/>
    <inertia ixx="1e-05" iyy="1e-05" izz="1e-05" ixy="0" iyz="0" ixz="0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry><box size="0.03 0.03 0.03"/></geometry>
    <material name="blue">
      <color rgba="0 0 0.8 1"/>
    </material>
  </visual>
</link>
<!-- Camera: mounted above base_link, pitched down to see ArUco board.
     base_link is at world Z=-0.209, so camera local z=0.85 → world Z≈0.64.
     Board is at world (0.5, 0, 0.35). Camera yaw=π cancels parent yaw.
     Pitch=0.57 tilts camera down toward the board. -->
<joint name="camera_joint" type="fixed">
  <origin xyz="-0.05 0 0.85" rpy="0 0.57 3.14159265359"/>
  <parent link="base_link"/>
  <child link="camera_link"/>
</joint>

<link name="camera_optical_link"/>
<!-- Optical frame standard: z forward, x right, y down -->
<joint name="camera_optical_joint" type="fixed">
  <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  <parent link="camera_link"/>
  <child link="camera_optical_link"/>
</joint>

</robot>
